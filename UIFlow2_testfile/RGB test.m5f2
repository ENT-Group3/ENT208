{"version":"V2.0","versionNumber":"V2.4.3","type":"stickc-plus","components":[{"name":"screen","type":"screen","layer":0,"screenId":"builtin","screenName":"","id":"__stickc-plus_screen","createTime":1772683696265,"x":0,"y":0,"width":135,"height":240,"backgroundColor":"#000000","size":0,"isSelected":true},{"name":"label0","type":"label","layer":1,"screenId":"builtin","screenName":"","id":"r7ZmLIJNT`K*9@L8","createTime":1772797673331,"x":34,"y":18,"color":"#ffffff","backgroundColor":"#222222","text":"value:","font":"Widgets.FONTS.DejaVu18","rotation":0,"isSelected":false},{"name":"label1","type":"label","layer":2,"screenId":"builtin","screenName":"","id":"sH0LyN!pPwuZ=$m7","createTime":1772797692491,"x":127,"y":19,"color":"#ffffff","backgroundColor":"#222222","text":"label1","font":"Widgets.FONTS.DejaVu18","rotation":0,"isSelected":false},{"name":"Status","type":"label","layer":3,"screenId":"builtin","screenName":"","id":"nIVo2Be4-!1Z@dBY","createTime":1772797695778,"x":33,"y":76,"color":"#ffffff","backgroundColor":"#222222","text":"Status","font":"Widgets.FONTS.DejaVu18","rotation":0,"isSelected":false},{"name":"label3","type":"label","layer":4,"screenId":"builtin","screenName":"","id":"uQ6mlSCNA=ILyliJ","createTime":1772797697035,"x":128,"y":78,"color":"#ffffff","backgroundColor":"#222222","text":"label3","font":"Widgets.FONTS.DejaVu18","rotation":0,"isSelected":false}],"resources":[{"hardware":["hardware_button","hardware_pin_button","imu","rgb","speaker","timer","ir"]}],"units":[],"hats":[],"caps":[],"chains":[],"bases":[],"plcmodules":[],"i2cs":[],"chainBus":[],"blockly":"<variables><variable id=\":uTeXm%bwM,|yfsM92)R\">x</variable><variable id=\"eIl3ERM!^q#`Rp:ALm{Y\">y</variable><variable id=\"@;344Fr5m,.heH8DH,^7\">z</variable></variables><block type=\"basic_on_setup\" id=\"setup_block\" deletable=\"false\" x=\"110\" y=\"50\"><mutation isBegin=\"true\"></mutation><field name=\"UPDATEOP\">true</field><statement name=\"FUNC\"><block type=\"system_m5_begin\" id=\"k^%Y[gf:6OuAjCVk`8:a\"><next><block type=\"rgb_set_brightness\" id=\"/W@mg)[5yv`CCf$u7M4U\"><field name=\"NAME\"></field><value name=\"BRIGHTNESS\"><shadow type=\"math_slider\" id=\"fue-ylY|[r:BSO2VVrpU\"><mutation max=\"100\" min=\"0\" step=\"1\" precision=\"1\"></mutation><field name=\"NUM\">10</field></shadow></value><next><block type=\"rgb_init\" id=\"~VrVK.0P{0thRjg_%pXv\"><mutation mode=\"customize\"></mutation><field name=\"MODE\">customize</field><field name=\"TYPE\">SK6812</field><value name=\"NAME\"><shadow type=\"math_number\" id=\"g+=?Bms(4$!Ca2?T^6KH\"><mutation max=\"Infinity\" min=\"-Infinity\" precision=\"0\"></mutation><field name=\"NUM\">32</field></shadow></value><value name=\"NUMBER\"><shadow type=\"math_number\" id=\".t3Fav+7fW0!WxGFn6!E\"><mutation max=\"Infinity\" min=\"-Infinity\" precision=\"0\"></mutation><field name=\"NUM\">30</field></shadow></value><next><block type=\"rgb_fill_color\" id=\";I9$||x]{b_}gtF2Lw_G\"><field name=\"NAME\">32</field><value name=\"COLOR\"><block type=\"color_rgb_palette\" id=\"mT8BE*+)}wn1.ky=;8vF\"><mutation mode=\"palette\"></mutation><field name=\"MODE\">palette</field><field name=\"COLOR\">#cc0000</field></block></value></block></next></block></next></block></next></block></statement></block><block type=\"imu_get_accel_var\" id=\"`62$APQFpxzt]rql3zS@\" disabled=\"true\" x=\"1170\" y=\"110\"><value name=\"X\"><block type=\"variables_get\" id=\"#T1O2Kha{.7JHZgP;jLk\" disabled=\"true\"><field name=\"VAR\" id=\":uTeXm%bwM,|yfsM92)R\">x</field></block></value><value name=\"Y\"><block type=\"variables_get\" id=\"G2m=8SV}yqR,rnOi^;,Q\" disabled=\"true\"><field name=\"VAR\" id=\"eIl3ERM!^q#`Rp:ALm{Y\">y</field></block></value><value name=\"Z\"><block type=\"variables_get\" id=\"I*/;g~a1DLz6kzvf7G3,\" disabled=\"true\"><field name=\"VAR\" id=\"@;344Fr5m,.heH8DH,^7\">z</field></block></value></block><block type=\"basic_on_loop\" id=\"loop_block\" deletable=\"false\" x=\"130\" y=\"350\"><mutation isUpdate=\"true\"></mutation><field name=\"UPDATEOP\">true</field><statement name=\"FUNC\"><block type=\"system_m5_update\" id=\"%0if5s(O$;S?~fU%i7W)\"></block></statement></block><block type=\"label_set_text\" id=\"z5K/%Qt$Zd6MJ8QiB(7/\" disabled=\"true\" x=\"1010\" y=\"550\"><field name=\"NAME\">label3</field><value name=\"TEXT\"><shadow type=\"text\" id=\"_|my0Rm|I-[(z{2%buW?\" disabled=\"true\"><field name=\"TEXT\">end</field></shadow></value></block>","screen":[{"simulationName":"Built-in","type":"builtin","width":135,"height":240,"scale":0.67,"screenName":"","blockId":"","screenColorType":0,"rotation":1,"id":"builtin","createTime":1772683696264}],"logicWhenNum":0,"pythonCode":"import M5\nfrom M5 import *\nfrom hardware import RGB\nimport time\n\n# 1. 唤醒底层硬件\nM5.begin()\n\n# 2. 初始化你的灯带 (对应你刚才积木里创建的 rgb32)\n# 引脚为 32，数量为 10，型号为 SK6812/WS2812B\nrgb32 = RGB(io=32, n=30, type=\"SK6812\")\n# 👇 加上这一行来限制全局亮度 (0-100的整数，数字越小越暗)\nrgb32.set_brightness(20)\n# 3. 这是一个经典的“色轮”函数 (类似于一个简单的着色器 Shader)\n# 输入一个 0-255 的位置值，它会计算并返回一个渐变的 24位 RGB 颜色\ndef wheel(pos):\n    pos = pos % 256\n    if pos < 85:\n        return ((pos * 3) << 16) | ((255 - pos * 3) << 8) | 0\n    elif pos < 170:\n        pos -= 85\n        return ((255 - pos * 3) << 16) | 0 | (pos * 3)\n    else:\n        pos -= 170\n        return 0 | ((pos * 3) << 8) | (255 - pos * 3)\n\nprint(\"开始渲染彩虹流水动画！(在终端按 Ctrl+C 停止)\")\n\noffset = 0      # 颜色偏移量，相当于时间流逝的变量\nNUM_LEDS = 30   # 灯珠总数\n\ntry:\n    # 4. 动画主循环\n    while True:\n        for i in range(NUM_LEDS):\n            # i * 25 确保了相邻的灯珠颜色互相错开，形成彩虹的跨度\n            # + offset 则让整个彩虹随着时间向前推进\n            color = wheel(i * 25 + offset)\n            rgb32.set_color(i, color)  # 将计算好的颜色赋予对应的灯珠\n            \n        offset = (offset + 5) % 256  # 步进值：数字越大，彩虹流动得越剧烈\n        time.sleep(0.03)             # 帧率控制：0.03秒刷新一次 (约30帧/秒)\n        \nexcept KeyboardInterrupt:\n    # 当你强制停止程序时，将灯带全灭，避免刺眼\n    rgb32.fill_color(0x000000)\n    print(\"动画已停止\")","customList":[]}